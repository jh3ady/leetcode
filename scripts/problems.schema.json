{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jh3ady/leetcode/schemas/problems.json",
  "title": "Problems index",
  "type": "object",
  "required": ["problems"],
  "properties": {
    "$schema": { "type": "string" },
    "problems": {
      "type": "array",
      "items": { "$ref": "#/$defs/problem" }
    }
  },
  "$defs": {
    "problem": {
      "type": "object",
      "required": ["id", "slug", "title", "difficulty", "url", "solvedAt", "languages"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "title": { "type": "string", "minLength": 1 },
        "difficulty": { "enum": ["easy", "medium", "hard"] },
        "url": { "type": "string", "format": "uri" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "solvedAt": { "type": "string", "format": "date" },
        "languages": {
          "type": "array",
          "items": { "enum": ["rs", "ts", "php"] },
          "uniqueItems": true,
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
